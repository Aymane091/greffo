# Auth.js v5 — required
AUTH_SECRET=generate_with__openssl_rand_-base64_32

# PostgreSQL — Next.js / Auth adapter
POSTGRES_URL=postgresql://greffo:greffo_local@localhost:5432/greffo_dev

# Resend email provider
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=connexion@greffo.fr
RESEND_FROM_NAME=Greffo

# FastAPI backend URL
API_BASE_URL=http://localhost:8000

# Optional — public URL of the Next.js app (used for e.g. Open Graph)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
