# ── Base de données ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://greffo:greffo_local@localhost:5432/greffo_dev

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Object Storage (MinIO local / Scaleway S3 en prod) ───────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=greffo
S3_SECRET_KEY=greffo_local_secret
S3_REGION=fr-par
S3_BUCKET_AUDIOS=audios-raw
S3_BUCKET_TRANSCRIPTS=transcripts-json
S3_BUCKET_EXPORTS=exports-docx

# ── Auth ─────────────────────────────────────────────────────────
AUTH_SECRET=change_me_in_production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Stripe ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Emails (Resend) ──────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=no-reply@greffo.fr

# ── Modèles IA ───────────────────────────────────────────────────
HUGGINGFACE_TOKEN=hf_...
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ── Monitoring ───────────────────────────────────────────────────
SENTRY_DSN=
ENVIRONMENT=local
